#. translators: %1$s, %2$s and %3$s are placeholders for URLs.
#: includes/class-kickstart.php:895
#, php-format
msgid ""
"All mail <strong>subject, body and signature contents</strong> can be "
"implemented based on\n"
"the flexible <a href=\"%1$s\" target=\"_blank\">template engine Twig 3</a>. "
"The following variables can be used\n"
"in the related input fields:<br><br>\n"
"\n"
"<strong>General</strong>\n"
"\n"
"<dl>\n"
"\t<dt><code>{{ site_title }}</code></dt>\n"
"\t<dd>Website title</dd>\n"
"\n"
"\t<dt><code>{{ site_title_limited }}</code></dt>\n"
"\t<dd>Website title (max. 20 characters)</dd>\n"
"\n"
"\t<dt><code>{{ site_url }}</code></dt>\n"
"\t<dd>Website URL (home page)</dd>\n"
"\n"
"\t<dt><code>{{ form_data }}</code></dt>\n"
"\t<dd><strong>All</strong> user-submitted form data excluding empty fields "
"(see below) combined</dd>\n"
"\n"
"\t<dt><code>{{ company_name }}</code></dt>\n"
"\t<dd>Company name provided on the <a href=\"%2$s\">Basic Settings tab</a></"
"dd>\n"
"\n"
"\t<dt><code>{{ company_address }}</code></dt>\n"
"\t<dd>Company address provided on the <a href=\"%2$s\">Basic Settings tab</"
"a></dd>\n"
"</dl>"
msgstr ""
"Alle Mailinhalte (<strong>Betreff, Mailtext und Signatur)</strong> werden "
"auf Basis der\n"
"flexiblen <a href=\"%1$s\" target=\"_blank\">Template-Engine Twig 3</a> "
"umgesetzt. Die folgenden Variablen\n"
"können in den zugehörigen Eingabefeldern verwendet werden:<br><br>\n"
"\n"
"<strong>Allgemein</strong>\n"
"\n"
"<dl>\n"
"\t<dt><code>{{ site_title }}</code></dt>\n"
"\t<dd>Website-Titel</dd>\n"
"\n"
"\t<dt><code>{{ site_title_limited }}</code></dt>\n"
"\t<dd>Website-Titel (max. 20 Zeichen)</dd>\n"
"\n"
"\t<dt><code>{{ site_url }}</code></dt>\n"
"\t<dd>Website-URL (Startseite)</dd>\n"
"\n"
"\t<dt><code>{{ form_data }}</code></dt>\n"
"\t<dd><strong>Alle</strong> von Benutzern übermittelte Formulardaten (siehe "
"unten) kombiniert</dd>\n"
"\n"
"\t<dt><code>{{ company_name }}</code></dt>\n"
"\t<dd>Firma, die im Tab <a href=\"%2$s\">Grundeinstellungen</a> hinterlegt "
"wurde</dd>\n"
"\n"
"\t<dt><code>{{ company_address }}</code></dt>\n"
"\t<dd>Adresse, die im Tab <a href=\"%2$s\">Grundeinstellungen</a> hinterlegt "
"wurde</dd>\n"
"</dl>"

