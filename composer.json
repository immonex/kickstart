{
    "name": "immonex/kickstart",
    "config": {
        "platform": {
            "php": "8.1"
        }
    },
    "repositories": [],
    "minimum-stability": "dev",
    "require": {
        "cmb2/cmb2": "^2.11",
        "immonex/wp-free-plugin-core": "2.13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9",
        "doctrine/rst-parser": "@dev",
        "yoast/phpunit-polyfills": "^4"
    },
    "autoload": {
        "psr-4": {
            "immonex\\Kickstart\\": [
                "includes"
            ]
        },
        "files": [
            "vendor/cmb2/cmb2/init.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "immonex\\Kickstart\\tests\\": "tests/"
        }
    }
}